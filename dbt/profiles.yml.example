flights:
  target: prod
  outputs:
    prod:
      type: bigquery
      method: service-account
      project: your-project-id       # ← replace with your GCP project ID
      dataset: flights_dbt
      keyfile: ../keys/gcp-creds.json  # ← path to your service account key
      location: US
      threads: 8
      timeout_seconds: 300